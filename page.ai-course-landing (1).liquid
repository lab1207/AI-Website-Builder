        <script>
            document.addEventListener('DOMContentLoaded', () => {
                // --- Mobile Scroll Animation Logic ---
                const observerOptions = { threshold: 0.1 };
                const observer = new IntersectionObserver((entries) => {
                    entries.forEach(entry => {
                        if (entry.isIntersecting) {
                            entry.target.classList.remove('opacity-0');
                            entry.target.classList.add('animate-fade-in-up');
                            observer.unobserve(entry.target);
                        }
                    });
                }, observerOptions);
                
                document.querySelectorAll('.mobile-curriculum-card').forEach(el => {
                    if (el.classList.contains('opacity-0')) {
                        observer.observe(el);
                    }
                });

                // --- Video Facade Logic ---
                const videoFacades = document.querySelectorAll('.video-facade');
                videoFacades.forEach(facade => {
                    facade.addEventListener('click', function() {
                        const videoId = this.getAttribute('data-video-id');
                        if(videoId) {
                            this.innerHTML = '<iframe width="100%" height="100%" src="https://www.youtube.com/embed/' + videoId + '?rel=0&modestbranding=1&autoplay=1" title="Video" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" allowfullscreen class="absolute inset-0 w-full h-full"></iframe>';
                        }
                    });
                });

                // --- Sticky Footer Logic ---
                const footer = document.getElementById('sticky-footer');
                if (footer) {
                    const handleScroll = () => {
                        if (window.scrollY > 300) {
                            footer.classList.remove('translate-y-full');
                            footer.classList.add('translate-y-0');
                        } else {
                            footer.classList.remove('translate-y-0');
                            footer.classList.add('translate-y-full');
                        }
                    };
                    handleScroll();
                    window.addEventListener('scroll', handleScroll);
                }

                // --- FAQ Logic ---
                const faqItems = document.querySelectorAll('.faq-item');
                faqItems.forEach(item => {
                    const trigger = item.querySelector('.faq-trigger');
                    const content = item.querySelector('.faq-content');
                    
                    if(trigger && content) {
                        trigger.addEventListener('click', () => {
                            const isOpen = !content.classList.contains('max-h-0');
                            
                            faqItems.forEach(otherItem => {
                                if(otherItem !== item) {
                                    const otherContent = otherItem.querySelector('.faq-content');
                                    const otherToggleBtn = otherItem.querySelector('.faq-toggle-btn');
                                    const otherNumber = otherItem.querySelector('.faq-number');
                                    const otherQuestion = otherItem.querySelector('.faq-question');
                                    
                                    if(otherContent) {
                                        otherContent.classList.remove('max-h-96', 'opacity-100');
                                        otherContent.classList.add('max-h-0', 'opacity-0');
                                    }
                                    
                                    otherItem.classList.remove('bg-[#0F0F11]', 'border-orange-500/40', 'shadow-[0_4px_20px_-10px_rgba(249,115,22,0.3)]');
                                    otherItem.classList.add('bg-[#0a0a0a]', 'border-white/10');
                                    
                                    if(otherToggleBtn) {
                                        otherToggleBtn.classList.remove('bg-orange-500', 'text-white');
                                        otherToggleBtn.classList.add('bg-zinc-800', 'text-gray-400');
                                        const oPlus = otherItem.querySelector('.faq-icon-plus');
                                        const oMinus = otherItem.querySelector('.faq-icon-minus');
                                        if(oPlus) oPlus.style.display = 'block';
                                        if(oMinus) oMinus.style.display = 'none';
                                    }
                                    if(otherNumber) {
                                        otherNumber.classList.remove('bg-orange-500', 'text-white');
                                        otherNumber.classList.add('bg-zinc-800', 'text-gray-500');
                                    }
                                    if(otherQuestion) {
                                        otherQuestion.classList.remove('text-white');
                                        otherQuestion.classList.add('text-gray-300');
                                    }
                                }
                            });

                            const toggleBtn = item.querySelector('.faq-toggle-btn');
                            const iconPlus = item.querySelector('.faq-icon-plus');
                            const iconMinus = item.querySelector('.faq-icon-minus');
                            const numberBadge = item.querySelector('.faq-number');
                            const questionText = item.querySelector('.faq-question');

                            if (!isOpen) {
                                content.classList.remove('max-h-0', 'opacity-0');
                                content.classList.add('max-h-96', 'opacity-100');
                                item.classList.remove('bg-[#0a0a0a]', 'border-white/10');
                                item.classList.add('bg-[#0F0F11]', 'border-orange-500/40', 'shadow-[0_4px_20px_-10px_rgba(249,115,22,0.3)]');
                                if(toggleBtn) {
                                    toggleBtn.classList.remove('bg-zinc-800', 'text-gray-400');
                                    toggleBtn.classList.add('bg-orange-500', 'text-white');
                                    if(iconPlus) iconPlus.style.display = 'none';
                                    if(iconMinus) iconMinus.style.display = 'block';
                                }
                                if(numberBadge) {
                                    numberBadge.classList.remove('bg-zinc-800', 'text-gray-500');
                                    numberBadge.classList.add('bg-orange-500', 'text-white');
                                }
                                if(questionText) {
                                    questionText.classList.remove('text-gray-300');
                                    questionText.classList.add('text-white');
                                }
                            } else {
                                content.classList.remove('max-h-96', 'opacity-100');
                                content.classList.add('max-h-0', 'opacity-0');
                                item.classList.remove('bg-[#0F0F11]', 'border-orange-500/40', 'shadow-[0_4px_20px_-10px_rgba(249,115,22,0.3)]');
                                item.classList.add('bg-[#0a0a0a]', 'border-white/10');
                                if(toggleBtn) {
                                    toggleBtn.classList.remove('bg-orange-500', 'text-white');
                                    toggleBtn.classList.add('bg-zinc-800', 'text-gray-400');
                                    if(iconPlus) iconPlus.style.display = 'block';
                                    if(iconMinus) iconMinus.style.display = 'none';
                                }
                                if(numberBadge) {
                                    numberBadge.classList.remove('bg-orange-500', 'text-white');
                                    numberBadge.classList.add('bg-zinc-800', 'text-gray-500');
                                }
                                if(questionText) {
                                    questionText.classList.remove('text-white');
                                    questionText.classList.add('text-gray-300');
                                }
                            }
                        });
                    }
                });

                // --- Countdown Logic ---
                const updateCountdown = () => {
                    const daysEl = document.querySelector('[data-timer="days"]');
                    const hoursEl = document.querySelector('[data-timer="hours"]');
                    const minsEl = document.querySelector('[data-timer="min"]');
                    const secsEl = document.querySelector('[data-timer="sec"]');

                    if(secsEl && minsEl && hoursEl && daysEl) {
                        let s = parseInt(secsEl.innerText);
                        let m = parseInt(minsEl.innerText);
                        let h = parseInt(hoursEl.innerText);
                        let d = parseInt(daysEl.innerText);

                        s--;
                        if(s < 0) { s = 59; m--; }
                        if(m < 0) { m = 59; h--; }
                        if(h < 0) { h = 23; d--; }
                        
                        secsEl.innerText = s.toString().padStart(2, '0');
                        minsEl.innerText = m.toString().padStart(2, '0');
                        hoursEl.innerText = h.toString().padStart(2, '0');
                        daysEl.innerText = d.toString().padStart(2, '0');
                    }
                };
                setInterval(updateCountdown, 1000);

                // --- Curriculum Animation Logic (Desktop) ---
                const desktopContainer = document.getElementById('curriculum-desktop-container');
                const progressBtns = document.querySelectorAll('.curriculum-progress-bar .progress-btn');

                if (desktopContainer && window.innerWidth >= 768) {
                    const cards = desktopContainer.querySelectorAll('.curriculum-card');
                    let activeIndex = 0;
                    let intervalId = null;
                    let isPaused = false;
                    
                    const updateCards = () => {
                         cards.forEach((card, index) => {
                            const isFuture = index > activeIndex;
                            const isPast = index < activeIndex;
                            const isActive = index === activeIndex;
                            
                            // 1. Positional Transforms & Opacity
                            card.style.zIndex = index.toString();
                            card.style.opacity = isFuture ? '0' : '1';
                            if (isFuture) {
                                card.style.transform = 'translateY(110%) scale(0.95)';
                            } else if (isPast) {
                                card.style.transform = 'translateY(0) scale(0.98)';
                            } else {
                                card.style.transform = 'translateY(0) scale(1)';
                            }

                            // 2. Inner Card Styling (Borders, Shadows, Gradients)
                            const innerCard = card.querySelector('.curriculum-card-inner');
                            if (innerCard) {
                                if (isActive) {
                                    innerCard.classList.add('border-orange-500/30', 'shadow-orange-900/10');
                                    // Add gradient overlay if missing
                                    if (!innerCard.querySelector('.active-gradient-overlay')) {
                                        const overlay = document.createElement('div');
                                        overlay.className = 'active-gradient-overlay absolute inset-0 bg-gradient-to-b from-orange-500/5 to-transparent pointer-events-none';
                                        innerCard.prepend(overlay);
                                    }
                                } else {
                                    innerCard.classList.remove('border-orange-500/30', 'shadow-orange-900/10');
                                    const overlay = innerCard.querySelector('.active-gradient-overlay');
                                    if (overlay) overlay.remove();
                                }
                            }

                            // 3. Badges
                            const badge = card.querySelector('.curriculum-badge');
                            if(badge) {
                                badge.className = isActive 
                                    ? 'curriculum-badge text-xs font-extrabold px-4 py-1.5 rounded-full uppercase tracking-wider shadow-lg bg-gradient-to-r from-orange-600 to-red-600 text-white'
                                    : 'curriculum-badge text-xs font-extrabold px-4 py-1.5 rounded-full uppercase tracking-wider shadow-lg bg-zinc-800 text-gray-500';
                            }

                            // 4. Title Color
                            const title = card.querySelector('.curriculum-title');
                            if(title) {
                                title.style.color = isActive ? 'white' : '#d1d5db';
                            }
                            
                            // 5. Lesson Checkmark Colors
                            const lessons = card.querySelectorAll('.group\\/lesson');
                            lessons.forEach((lesson, lIdx) => {
                                 const circle = lesson.firstElementChild;
                                 const text = lesson.lastElementChild;
                                 
                                 if (isActive) {
                                     circle.className = 'min-w-[28px] h-7 mt-1 rounded-full flex items-center justify-center text-xs font-bold border transition-colors duration-300 bg-orange-500/10 border-orange-500/50 text-orange-500';
                                     // Ensure checkmark icon is handled if using innerHTML swap, 
                                     // but CSS toggle is usually enough if React rendered structure is stable.
                                     // Here we trust the layout structure.
                                     text.className = 'transition-colors duration-300 text-gray-200';
                                 } else {
                                     circle.className = 'min-w-[28px] h-7 mt-1 rounded-full flex items-center justify-center text-xs font-bold border transition-colors duration-300 bg-zinc-800 border-white/10 text-gray-600';
                                     text.className = 'transition-colors duration-300 text-gray-500';
                                 }
                            });
                        });

                        // 6. Progress Bars
                        progressBtns.forEach((btn, idx) => {
                            if(idx === activeIndex) {
                                btn.className = 'progress-btn h-1.5 rounded-full transition-all duration-300 w-12 bg-orange-500';
                            } else if (idx < activeIndex) {
                                btn.className = 'progress-btn h-1.5 rounded-full transition-all duration-300 w-4 bg-orange-900/50';
                            } else {
                                btn.className = 'progress-btn h-1.5 rounded-full transition-all duration-300 w-4 bg-zinc-800';
                            }
                        });
                    };

                    const startLoop = () => {
                        if(intervalId) clearInterval(intervalId);
                        intervalId = setInterval(() => {
                            if(!isPaused) {
                                activeIndex = (activeIndex + 1) % cards.length;
                                updateCards();
                            }
                        }, 3500);
                    };

                    progressBtns.forEach((btn, idx) => {
                        btn.addEventListener('click', () => {
                            activeIndex = idx;
                            updateCards();
                            startLoop(); 
                        });
                    });

                    const wrapper = desktopContainer.parentElement;
                    if(wrapper) {
                        wrapper.addEventListener('mouseenter', () => { isPaused = true; });
                        wrapper.addEventListener('mouseleave', () => { isPaused = false; });
                    }

                    // Force initial update to correct state
                    updateCards();
                    startLoop();
                }
            });
        </script></body></html>